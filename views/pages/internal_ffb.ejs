                    </div>
                    <div class="d-flex gap-3 mb-2">
                      <div class="flex-fill">
                        <label id="divisionLabel" class="form-label text-uppercase" for="division"> Divisi </label>
                        <select class="js-select2 form-control fw-light text-uppercase" onchange="selectBlock()" name="division" id="division" style="width: 100%"></select>
                      </div>
                      <div class="flex-fill">
                        <label id="blockLabel" class="form-label text-uppercase" for="block"> Blok </label>
                        <select class="js-select2 form-select fw-light text-uppercase" name="block[]" id="block" style="width: 100%" multiple></select>
                      </div>
                    </div>
                    <div class="d-flex gap-3 mb-2">
                      <div class="flex-fill">
                        <label id="noVehicleLabel" class="form-label text-uppercase" for="noVehicle">No Polisi</label>
