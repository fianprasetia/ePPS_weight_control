                      </div>
                    </div>
                    <div class="d-flex gap-3">
                      <div class="flex-fill mb-2">
                        <label id="unripeLabel" class="form-label text-uppercase" for="unripe">mentah</label>
                        <input type="text" class="form-control fw-light text-uppercase text-end" onkeyup="validateDouble(this)" value="0" onfocus="removeZero(this)" id="unripe" name="unripe" />
                      </div>
