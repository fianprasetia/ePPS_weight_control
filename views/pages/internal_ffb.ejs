                        <input type="text" class="form-control fw-light text-uppercase text-end" onkeyup="validateDouble(this)" value="0" onfocus="removeZero(this)" id="totalBunches" name="totalBunches" />
                      </div>
                      <div class="flex-fill">
                        <label id="looseFruitLabel" class="form-label text-uppercase" for="looseFruit">BRONDOLAN</label>
                        <input type="text" class="form-control fw-light text-uppercase text-end" onkeyup="validateDouble(this)" value="0" onfocus="removeZero(this)" id="looseFruit" name="looseFruit" />
