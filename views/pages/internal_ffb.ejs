                    </div>
                  </div>
                </div>
                <div class="">
                  <div class="row mt-4">
                    <div class="col-sm-4 border-end">
                      <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                          <div class="text-primary mb-2"><i class="fa fa-arrow-down fa-3x"></i></div>
                          <div id="incomingWeighing" class="fw-bold text-primary">TIMBANG MASUK</div>
                        </div>
                        <div class="col-md-7 border-end">
                          <div class="row mb-2">
                            <label class="col-sm-4 col-form-label text-uppercase" id="dateInLabel" for="dateIn">Waktu</label>
                            <div class="col-sm-8">
                              <input type="text" class="form-control fw-bold text-end" id="dateIn" name="dateIn" disabled />
                            </div>
                          </div>
                          <div class="row">
                            <label class="col-sm-4 col-form-label text-uppercase" id="weightInLabel" for="weightIn">Berat</label>
                            <div class="col-sm-8">
                              <input type="text" class="form-control fw-bold text-end" id="weightIn" name="weightIn" value="0" disabled />
                            </div>
                          </div>
                        </div>
                        <div class="col-md-3 text-center">
                          <a href="javascript:void(0);" id="getWeightInBtn" onclick="getWeightIn()" class="btn btn-primary px-4 py-4 fw-bold">
                            <div id="getWeightIn">GET WEIGHT</div>
                          </a>
                        </div>
                      </div>
                    </div>
                    <div class="col-sm-4 border-end">
                      <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                          <div class="text-primary mb-2"><i class="fa fa-arrow-up fa-3x"></i></div>
                          <div id="outgoingWeighing" class="fw-bold text-primary">TIMBANG KELUAR</div>
                        </div>
                        <div class="col-md-7 border-end">
                          <div class="row mb-2">
                            <label class="col-sm-4 col-form-label text-uppercase" id="dateOutLabel" for="dateOut">Waktu</label>
                            <div class="col-sm-8">
                              <input type="text" class="form-control fw-bold text-end" id="dateOut" name="dateOut" disabled />
                            </div>
                          </div>
                          <div class="row">
                            <label class="col-sm-4 col-form-label text-uppercase" id="weightOutLabel" for="weightOut">Berat</label>
                            <div class="col-sm-8">
                              <input type="text" class="form-control fw-bold text-end" id="weightOut" name="weightOut" value="0" disabled />
                            </div>
                          </div>
                        </div>
                        <div class="col-md-3 text-center">
                          <a href="javascript:void(0);" id="getWeightOutBtn" onclick="getWeightOut()" class="btn btn-secondary px-4 py-4 fw-bold">
                            <div id="getWeightOut">GET WEIGHT</div>
                          </a>
                        </div>
                      </div>
                    </div>
                    <div class="col-sm-4">
                      <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                          <div class="text-primary mb-2"><i class="fa-regular fa-circle-check fa-3x"></i></div>
                          <div id="total" class="fw-bold text-primary">TOTAL</div>
                        </div>
                        <div class="col-md-7 border-end">
                          <div class="row mb-2">
                            <label class="col-sm-4 col-form-label text-uppercase" id="grossWeightLabel" for="grossWeight">brutto</label>
                            <div class="col-sm-8">
                              <input type="text" class="form-control fw-bold text-end" id="grossWeight" value="0" name="grossWeight" disabled />
                            </div>
                          </div>
                          <div class="row mb-2">
                            <label class="col-sm-4 col-form-label text-uppercase" id="deductionLabel" for="deduction">potongan</label>
                            <div class="col-sm-8">
                              <input type="text" class="form-control fw-bold text-end" id="deduction" value="0" name="deduction" disabled />
                            </div>
                          </div>
                          <div class="row">
                            <label class="col-sm-4 col-form-label text-uppercase" id="netWeightLabel" for="netWeight">netto</label>
                            <div class="col-sm-8">
                              <input type="text" class="form-control fw-bold text-end" id="netWeight" name="netWeight" value="0" disabled />
                            </div>
                          </div>
                        </div>
                        <div id="load" class="col-md-3 text-center">
                          <a id="saveBtn" href="javascript:void(0);" class="btn btn-secondary px-4 py-4 fw-bold" onclick="save()" disabled>
                            <div id="save" class="text-uppercase">SAVE & Print</div>
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
        <div class="">
          <div class="block block-rounded">
            <div class="block-content block-content-full">
              <div class="d-flex align-items-center gap-2 mb-4">
                <i class="fa-solid fa-scale-balanced fa-2x text-primary"></i>
