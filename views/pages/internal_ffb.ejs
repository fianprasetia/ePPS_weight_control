                      <th id="divisionThead" class="text-center text-uppercase">divsi</th>
                      <th id="plantingYearThead" class="text-center text-uppercase">tahun Tanam</th>
                    </tr>
                  </thead>
                  <tbody id="dataTableItem"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </main>
      <footer id="page-footer" class="bg-body-light"><%- include('../partials/footer'); %></footer>
