<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/login_head'); %>
  </head>

  <body>
    <div id="page-container">
      <main id="main-container">
        <div class="bg-image" style="background-image: url('assets/media/photos/weighbridge.png')">
          <div class="row g-0 justify-content-center bg-primary-dark-op">
            <div class="hero-static col-sm-8 col-md-6 col-xl-4 d-flex align-items-center p-1 px-sm-0">
              <div class="block block-transparent block-rounded w-100 mb-0 overflow-hidden">
                <div class="block-content block-content-full bg-body-extra-light">
                  <div class="d-flex bd-highlight">
                    <div class="ms-auto">
                      <div class="dropdown dropleft push">
                        <button type="button" id="selectLanguage" class="btn dropdown-toggle fw-light my-auto border-0" id="dropdown-dropleft-dark" data-bs-toggle="dropdown" aria-haspopup="true" value="id" aria-expanded="false">
                          <img class="border border-secondary rounded-circle" style="width: 15px" src="file/flag/earth.png" />
                          Language / Bahasa
                        </button>
                        <div class="dropdown-menu text-end" aria-labelledby="dropdown-dropleft-dark">
                          <a onclick="language(id)" id="en" class="dropdown-item text-end fw-light"><img class="border border-secondary rounded-circle" style="width: 15px" src="file/flag/usa.png" /> English</a>
                          <a onclick="language(id)" id="id" class="dropdown-item text-end fw-light"><img class="border border-secondary rounded-circle" style="width: 15px" src="file/flag/indonesia.png" /> Indonesia</a>
                          <a onclick="language(id)" id="zh" class="dropdown-item text-end fw-light"><img class="border border-secondary rounded-circle" style="width: 15px" src="file/flag/china.png" /> 汉语</a>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="mb-2 text-center">
                    <a class="link-fx fw-bold fs-1">
                      <span class="text-dark">ePPS</span>
                    </a>
                    <p id="loginHeader" class="text-uppercase fw-bold fs-sm text-muted">weight control</p>
                  </div>
                  <form class="needs-validation" novalidate>
                    <div class="mb-4">
                      <input type="username" class="form-control fw-light" id="username" name="username" placeholder="Nama Pengguna" required />
                    </div>
                    <div class="input-group mb-4">
                      <input type="password" class="form-control fw-light" id="password" name="password" placeholder="Kata Sandi" required />
                      <span class="input-group-text bg-transparent" onclick="viewPassword('password', 'eyeIcon')">
                        <i class="fa-solid fa-eye-slash" id="eyeIcon"></i>
                      </span>
                    </div>
                    <div id="loadlogin" class="mb-4">
                      <a onclick="login()" type="submit" class="btn w-100 btn-hero btn-primary shadow"><i class="fa fa-fw fa-sign-in-alt opacity-50 me-1"></i> <span id="loginButton">Log In</span></a>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
    <script src="assets/js/lib/jquery.min.js"></script>
    <script src="assets/js/plugins/bootstrap-notify/bootstrap-notify.min.js"></script>
    <script src="assets/js/plugins/jquery-validation/jquery.validate.min.js"></script>
    <script src="assets/js/plugins/jquery-validation/additional-methods.js"></script>
    <script src="assets/js/dashmix.app.min.js"></script>
    <script src="js/mainUrl.js"></script>
    <script src="js/session.js"></script>
    <script src="js/login.js"></script>
    <script>
      Dashmix.helpersOnLoad(["jq-notify"]);
    </script>
  </body>
</html>
