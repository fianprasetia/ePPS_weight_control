<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../partials/head'); %>
  </head>

  <body>
    <div id="page-container" class="sidebar-dark enable-page-overlay side-scroll page-header-fixed page-footer-fixed side-trans-enabled">
      <nav id="sidebar" aria-label="Main Navigation"><%- include('../partials/navigasi'); %></nav>
      <!-- END Sidebar -->

      <!-- Header -->
      <header id="page-header">
        <!-- Header Content -->
        <%- include('../partials/header'); %>
      </header>
      <!-- END Header -->

      <!-- Main Container -->
      <main id="main-container">
        <!-- Page Content -->
        <div class="content">
          <h4 id="titlePage" class="content-heading text-uppercase"></h4>
          <div class="block block-rounded">
            <div class="block-header">
              <!-- <h3 class="block-title">add</h3> -->
              <div class="block-title">
                <button title="Add" type="submit" onclick="showModalInsertPartners()" class="btn btn-primary">
                  <i class="fa-solid fa-plus"></i>
                </button>
              </div>
              <div class="block-options">
                <button type="button" class="btn-block-option" data-toggle="block-option" data-action="fullscreen_toggle"></button>
              </div>
            </div>
            <div class="block-content block-content-full">
              <div id="rowUsers" class="row table-responsive">
                <table class="table table-bordered table-striped table-vcenter js-dataTable-responsive">
                  <thead>
                    <tr>
                      <th id="codePartnersThead" class="text-center text-uppercase">Code Partners</th>
                      <th id="nameThead" class="text-center text-uppercase">Name</th>
                      <!-- <th id="addressThead" class="text-center text-uppercase">Address</th> -->
                      <th id="cityThead" class="text-center text-uppercase">City</th>
                      <!-- <th id="phoneThead" class="text-center text-uppercase">Phone</th>
                      <th id="emailThead" class="text-center text-uppercase">Email</th> -->
                      <th id="contactPersonThead" class="text-center text-uppercase">Contact Person</th>
                      <th id="supplierThead" class="text-center text-uppercase">Supplier</th>
                      <th id="supplierTBSThead" class="text-center text-uppercase">Supplier TBS</th>
                      <th id="transporterThead" class="text-center text-uppercase">Transporter</th>
                      <th id="statusThead" class="text-center text-uppercase">Status</th>
                      <th id="actionsThead" class="text-center text-uppercase">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="dataTable"></tbody>
                </table>
              </div>
            </div>
          </div>
          <!-- END Store Growth -->
        </div>
      </main>
      <footer id="page-footer" class="bg-body-light"><%- include('../partials/footer'); %></footer>
    </div>
    <div class="modal" id="modalPartners" tabindex="-1" role="dialog" data-bs-backdrop="static" aria-labelledby="modalPartners" aria-hidden="true">
      <div class="modal-dialog modal-xl" role="document">
        <div class="modal-content">
          <div class="block block-rounded block-themed block-transparent mb-0">
            <div class="block-header bg-primary-dark">
              <h3 id="titleModal" class="block-title text-uppercase">Add Menu</h3>
              <div class="block-options">
                <button type="button" class="btn-block-option text-gray" data-toggle="block-option" data-action="fullscreen_toggle"></button>
              </div>
            </div>
            <form id="form1" class="js-validation">
              <div class="block-content">
                <div class="col-sm-12 mb-2">
                  <label id="nameLabel" class="form-label text-uppercase" for="name">Name</label>
                  <input type="text" class="form-control fw-light text-uppercase" id="name" name="name" />
                </div>
                <div class="col-sm-12 mb-2">
                  <label id="addressLabel" class="form-label text-uppercase" for="address">address</label>
                  <input type="text" class="form-control fw-light text-uppercase" id="address" name="address" />
                </div>
                <div class="col-sm-12 mb-2">
                  <label id="cityLabel" class="form-label text-uppercase" for="city">City</label>
                  <select class="js-select2 form-select fw-light text-uppercase" name="city" id="city" style="width: 100%" data-container="#modalPartners"></select>
                </div>
                <div class="col-sm-12 mb-2">
                  <label id="phoneLabel" class="form-label text-uppercase" for="phone">phone</label>
                  <input type="text" class="form-control fw-light" id="phone" name="phone" />
                </div>
                <div class="col-sm-12 mb-2">
                  <label id="emailLabel" class="form-label text-uppercase" for="email">email</label>
                  <input type="email" class="form-control fw-light" id="email" name="email" />
                </div>
                <div class="col-sm-12 mb-2">
                  <label id="contactNameLabel" class="form-label text-uppercase" for="contactName">Contact Person</label>
                  <input type="text" class="form-control fw-light text-uppercase" id="contactName" name="contactName" />
                </div>
                <div class="col-sm-12 mb-2">
                  <label id="typeLabel" class="form-label text-uppercase" for="type">Type</label>
                  <div class="row items-push">
                    <div class="col-md-4">
                      <div class="form-check form-block">
                        <input class="form-check-input" type="checkbox" id="isSupplier" name="isSupplier" />
                        <label class="form-check-label w-100 py-2" for="isSupplier">
                          <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                              <div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px">
                                <i class="fa-solid fa-box fa-xl"></i>
                              </div>
                            </div>
                            <div class="ms-3">
                              <div class="fw-semibold fs-5">Supplier</div>
                              <small class="text-muted">Mitra pemasok barang atau bahan baku</small>
                            </div>
                          </div>
                        </label>
                      </div>
                    </div>
                    <div class="col-md-4">
                      <div class="form-check form-block">
                        <input class="form-check-input" type="checkbox" id="isSupplierTBS" name="isSupplierTBS" />
                        <label class="form-check-label w-100 py-2" for="isSupplierTBS">
                          <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                              <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px">
                                <i class="fa-brands fa-pagelines fa-xl"></i>
                              </div>
                            </div>
                            <div class="ms-3">
                              <div class="fw-semibold fs-5">Supplier TBS</div>
                              <small class="text-muted"> Mitra pemasok Tandan Buah Segar </small>
                            </div>
                          </div>
                        </label>
                      </div>
                    </div>

                    <!-- Transportir -->
                    <div class="col-md-4">
                      <div class="form-check form-block">
                        <input class="form-check-input" type="checkbox" id="isTransporter" name="isTransporter" />

                        <label class="form-check-label w-100 py-2" for="isTransporter">
                          <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                              <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px">
                                <i class="fa-solid fa-truck fa-xl"></i>
                              </div>
                            </div>

                            <div class="ms-3">
                              <div class="fw-semibold fs-5">Transportir</div>
                              <small class="text-muted"> Penyedia jasa transportasi dan pengangkutan </small>
                            </div>
                          </div>
                        </label>
                      </div>
                    </div>
                    <label id="partnerType-error" class="invalid-feedback d-block text-danger"></label>
                  </div>
                </div>
                <div class="col-sm-12 mb-4">
                  <label id="statusLabel" class="form-label text-uppercase" for="status">Status</label>
                  <select class="js-select2 form-select fw-light text-uppercase" name="status" id="status" style="width: 100%" data-container="#modalPartners"></select>
                </div>
              </div>
              <div id="load" class="block-content block-content-full text-end bg-body"></div>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- 1. CORE LIBRARIES (jQuery MUST be first) -->
    <script src="assets/js/lib/jquery.min.js"></script>
    <script src="assets/js/dashmix.app.min.js"></script>

    <!-- 2. UTILITY/HELPER SCRIPTS -->
    <script src="js/mainUrl.js"></script>
    <script src="lib/loadingPage.js"></script>
    <script src="lib/epps.js"></script>

    <!-- 3. FORM VALIDATION & INPUT HANDLING -->
    <script src="assets/js/plugins/jquery-validation/jquery.validate.min.js"></script>
    <script src="assets/js/plugins/jquery-validation/additional-methods.js"></script>
    <script src="assets/js/plugins/jquery.maskedinput/jquery.maskedinput.min.js"></script>
    <script src="assets/js/plugins/bootstrap-maxlength/bootstrap-maxlength.min.js"></script>

    <!-- 4. UI COMPONENTS -->
    <script src="assets/js/plugins/select2/js/select2.full.min.js"></script>
    <script src="assets/js/plugins/flatpickr/flatpickr.min.js"></script>
    <script src="assets/js/plugins/bootstrap-notify/bootstrap-notify.min.js"></script>

    <!-- 5. DATATABLES SUITE -->
    <script src="assets/js/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="assets/js/plugins/datatables-bs5/js/dataTables.bootstrap5.min.js"></script>
    <script src="assets/js/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
    <script src="assets/js/plugins/datatables-responsive-bs5/js/responsive.bootstrap5.min.js"></script>
    <script src="assets/js/plugins/datatables-buttons/dataTables.buttons.min.js"></script>
    <script src="assets/js/plugins/datatables-buttons-bs5/js/buttons.bootstrap5.min.js"></script>
    <script src="assets/js/plugins/datatables-buttons-jszip/jszip.min.js"></script>
    <script src="assets/js/plugins/datatables-buttons-pdfmake/pdfmake.min.js"></script>
    <script src="assets/js/plugins/datatables-buttons-pdfmake/vfs_fonts.js"></script>
    <script src="assets/js/plugins/datatables-buttons/buttons.print.min.js"></script>
    <script src="assets/js/plugins/datatables-buttons/buttons.html5.min.js"></script>

    <!-- 6. DATA VISUALIZATION -->
    <script src="assets/js/plugins/chart.js/chart.umd.js"></script>

    <!-- 7. PAGE SPECIFIC SCRIPTS -->
    <script src="assets/js/pages/be_pages_dashboard.min.js"></script>

    <!-- 8. PARTNERS MODULE -->
    <script src="js/partners/selectPartners.js"></script>
    <script src="js/partners/insertPartners.js"></script>
    <script src="js/partners/updatePartners.js"></script>
    <script src="js/partners/deletePartners.js"></script>

    <!-- 9. INITIALIZATION (Single combined call) -->
    <script>
      Dashmix.helpersOnLoad(["js-flatpickr", "jq-datepicker", "jq-maxlength", "jq-select2", "jq-rangeslider", "jq-masked-inputs", "jq-pw-strength", "jq-notify"]);
    </script>
  </body>
</html>
